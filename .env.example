# Database credentials (required)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Google OAuth2 credentials (optional, for Google login)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here

# Restrict login to this Google Workspace domain (leave empty to allow all)
ALLOWED_DOMAIN=trixi.cz

# Frontend URL (set to your public domain in production)
FRONTEND_URL=http://localhost

# Enable username/password authentication (default: false, Google OAuth only)
PASSWORD_AUTH_ENABLED=false
